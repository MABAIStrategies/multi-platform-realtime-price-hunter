<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MAB AI Strategies - Interactive 3D Tech Stack Wireframe</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <!-- FontAwesome for Premium Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Three.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <!-- OrbitControls -->
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #030014;
            color: #f3f4f6;
            overflow-x: hidden;
        }
        .mono {
            font-family: 'JetBrains Mono', monospace;
        }
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #030014;
        }
        ::-webkit-scrollbar-thumb {
            background: #2a1b54;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #44337a;
        }
        /* Glowing Glassmorphism */
        .glass-panel {
            background: rgba(10, 5, 30, 0.75);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(139, 92, 246, 0.2);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.45);
        }
        .glow-indigo {
            box-shadow: 0 0 20px rgba(99, 102, 241, 0.25);
        }
        .active-tab {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.25) 0%, rgba(99, 102, 241, 0.15) 100%);
            border-color: rgba(139, 92, 246, 0.6);
            color: #ffffff;
        }
        /* Visual cues for mobile tap target sizes */
        .touch-target {
            min-width: 44px;
            min-height: 44px;
        }
        /* Custom Loading Spinner */
        .sparkle-spinner {
            border: 2px solid rgba(167, 139, 250, 0.1);
            border-top: 2px solid #a78bfa;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="w-full h-screen relative flex select-none">

    <!-- TOP HEADER / BRANDING -->
    <header class="absolute top-0 left-0 right-0 z-50 flex items-center justify-between p-4 md:p-6 pointer-events-none">
        <div class="flex items-center gap-3 pointer-events-auto bg-[#030014]/80 p-3 rounded-2xl border border-violet-500/10 backdrop-blur-md">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-violet-600 to-indigo-600 flex items-center justify-center shadow-lg shadow-violet-500/20">
                <i class="fa-solid fa-cubes text-white text-lg animate-pulse"></i>
            </div>
            <div>
                <h1 class="text-base md:text-lg font-extrabold tracking-wide text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-indigo-200">MAB AI STRATEGIES</h1>
                <p class="text-[10px] text-violet-400/80 tracking-widest uppercase mono">Interactive 3D Tech Stack v3.0</p>
            </div>
        </div>
        
        <div class="pointer-events-auto flex gap-2">
            <button onclick="resetCamera()" class="touch-target px-4 bg-violet-950/40 hover:bg-violet-900/40 border border-violet-500/30 text-xs text-violet-300 rounded-xl flex items-center gap-2 transition duration-200 backdrop-blur-md">
                <i class="fa-solid fa-video"></i> <span class="hidden md:inline">Reset View</span>
            </button>
            <button onclick="togglePipelineSim()" id="simBtn" class="touch-target px-4 bg-emerald-950/40 hover:bg-emerald-900/40 border border-emerald-500/30 text-xs text-emerald-300 rounded-xl flex items-center gap-2 transition duration-200 backdrop-blur-md">
                <i class="fa-solid fa-circle-play animate-pulse"></i> <span>Simulate Flow</span>
            </button>
        </div>
    </header>

    <!-- MAIN 3D CANVAS -->
    <div id="canvas-container" class="w-full h-full absolute inset-0 z-10 cursor-grab active:cursor-grabbing"></div>

    <!-- LEFT DRAWER: ARCHITECTURE EXPLORER & ✨ GEMINI AI WORKSPACE -->
    <aside class="absolute left-0 top-24 bottom-4 w-full md:w-[390px] px-4 z-40 pointer-events-none flex flex-col gap-4">
        
        <!-- Tab Selectors for Left Side Control -->
        <div class="pointer-events-auto flex gap-1 bg-[#0a051e]/90 p-1.5 rounded-2xl border border-violet-500/10 backdrop-blur-md">
            <button id="tabBtn-layers" onclick="switchLeftTab('layers')" class="flex-1 py-2 text-xs font-semibold rounded-xl text-center transition duration-150 active-tab">
                <i class="fa-solid fa-layer-group mr-1.5"></i>Layers
            </button>
            <button id="tabBtn-gemini" onclick="switchLeftTab('gemini')" class="flex-1 py-2 text-xs font-semibold rounded-xl text-center transition duration-150 text-violet-300/60 hover:text-white">
                <i class="fa-solid fa-wand-magic-sparkles mr-1.5"></i>✨ Gemini Hub
            </button>
        </div>

        <!-- TAB CONTENT: 1. STACK ARCHITECTURE LAYERS -->
        <div id="leftTab-layers" class="pointer-events-auto glass-panel rounded-2xl p-4 flex flex-col gap-3 max-h-[40%] overflow-y-auto">
            <div class="flex items-center justify-between border-b border-violet-500/10 pb-2">
                <span class="text-xs font-semibold uppercase tracking-wider text-violet-400">Stack Architecture Layers</span>
                <span id="nodesCount" class="text-[10px] mono bg-violet-500/20 px-2 py-0.5 rounded text-violet-200">25 Nodes Active</span>
            </div>
            
            <div class="flex flex-col gap-1.5">
                <!-- Layer 4 -->
                <button onclick="focusLayer(4)" id="layerBtn-4" class="touch-target flex items-center justify-between p-2 rounded-xl border border-violet-500/10 hover:border-violet-500/40 text-left transition duration-200 bg-violet-950/10 text-violet-300/80">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-amber-400"></span>
                        <span class="text-xs font-medium">1. Orchestration & Agents</span>
                    </div>
                    <i class="fa-solid fa-chevron-right text-[10px]"></i>
                </button>
                <!-- Layer 3 -->
                <button onclick="focusLayer(3)" id="layerBtn-3" class="touch-target flex items-center justify-between p-2 rounded-xl border border-violet-500/10 hover:border-violet-500/40 text-left transition duration-200 bg-violet-950/10 text-violet-300/80">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-fuchsia-400"></span>
                        <span class="text-xs font-medium">2. Brain & Cognitive Models</span>
                    </div>
                    <i class="fa-solid fa-chevron-right text-[10px]"></i>
                </button>
                <!-- Layer 2 -->
                <button onclick="focusLayer(2)" id="layerBtn-2" class="touch-target flex items-center justify-between p-2 rounded-xl border border-violet-500/10 hover:border-violet-500/40 text-left transition duration-200 bg-violet-950/10 text-violet-300/80">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-indigo-400"></span>
                        <span class="text-xs font-medium">3. Routers & Inference</span>
                    </div>
                    <i class="fa-solid fa-chevron-right text-[10px]"></i>
                </button>
                <!-- Layer 1 -->
                <button onclick="focusLayer(1)" id="layerBtn-1" class="touch-target flex items-center justify-between p-2 rounded-xl border border-violet-500/10 hover:border-violet-500/40 text-left transition duration-200 bg-violet-950/10 text-violet-300/80">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-teal-400"></span>
                        <span class="text-xs font-medium">4. Memory & Context Retrieval</span>
                    </div>
                    <i class="fa-solid fa-chevron-right text-[10px]"></i>
                </button>
                <!-- Layer 0 -->
                <button onclick="focusLayer(0)" id="layerBtn-0" class="touch-target flex items-center justify-between p-2 rounded-xl border border-violet-500/10 hover:border-violet-500/40 text-left transition duration-200 bg-violet-950/10 text-violet-300/80">
                    <div class="flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-blue-400"></span>
                        <span class="text-xs font-medium">5. Persistence & Infrastructure</span>
                    </div>
                    <i class="fa-solid fa-chevron-right text-[10px]"></i>
                </button>
            </div>
        </div>

        <!-- TAB CONTENT: 2. ✨ GEMINI AI WORKSPACE HUB -->
        <div id="leftTab-gemini" class="hidden pointer-events-auto glass-panel rounded-2xl p-4 flex flex-col gap-4 overflow-y-auto max-h-[60%]">
            <div class="border-b border-violet-500/15 pb-2">
                <span class="text-xs font-extrabold uppercase tracking-wider text-violet-300 flex items-center gap-1.5">
                    <i class="fa-solid fa-wand-magic-sparkles text-violet-400 animate-pulse"></i>
                    ✨ Custom AI Simulation Builder
                </span>
                <p class="text-[10px] text-gray-400 mt-1">Prompt Gemini to construct an interactive, custom 3D system pipeline using your active components.</p>
            </div>

            <!-- Custom Scenario Form -->
            <div class="flex flex-col gap-3">
                <label class="text-[11px] font-bold text-gray-300">Describe Your Business Automation Case:</label>
                <textarea id="geminiPromptInput" rows="3" class="w-full bg-[#120a2a] border border-violet-500/20 rounded-xl p-2.5 text-xs text-gray-200 focus:outline-none focus:border-violet-400 placeholder-gray-500" placeholder="e.g. When Claude Code merges a branch to GitHub, sync SQLite and broadcast to Slack..."></textarea>
                
                <button onclick="synthesizePipeline()" id="synthesizeBtn" class="touch-target w-full bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 text-white text-xs font-bold py-2.5 px-4 rounded-xl flex items-center justify-center gap-2 transition duration-150 shadow-md shadow-indigo-950/40">
                    <i id="synthesizeIcon" class="fa-solid fa-microchip"></i>
                    <span id="synthesizeBtnText">✨ Design & Generate 3D Sim</span>
                </button>
            </div>

            <!-- System Message Alert / Processing State -->
            <div id="geminiAlert" class="hidden bg-indigo-950/40 border border-indigo-500/30 p-3 rounded-xl flex items-start gap-2.5">
                <div id="geminiAlertSpinner" class="sparkle-spinner flex-shrink-0 mt-0.5"></div>
                <div class="flex-1">
                    <p id="geminiAlertTitle" class="text-xs font-bold text-indigo-300">Architecting Scenario...</p>
                    <p id="geminiAlertDesc" class="text-[10px] text-gray-300 mt-0.5">Gemini is arranging optimal nodes for logical flow consistency.</p>
                </div>
            </div>
        </div>

        <!-- Real-time Workflow Simulation Active State -->
        <div id="simulationPanel" class="pointer-events-auto glass-panel rounded-2xl p-4 flex flex-col gap-2 opacity-0 transform translate-y-4 pointer-events-none transition-all duration-300">
            <div class="flex items-center justify-between">
                <span class="text-xs font-semibold text-emerald-400 flex items-center gap-1.5 uppercase tracking-wider">
                    <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-ping absolute"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 relative"></span>
                    Active Data Sim Pipeline
                </span>
                <button onclick="togglePipelineSim()" class="text-xs text-gray-400 hover:text-white">
                    <i class="fa-solid fa-circle-xmark"></i>
                </button>
            </div>
            
            <div class="flex flex-col gap-2 mt-2">
                <div class="bg-emerald-950/30 border border-emerald-500/20 p-2.5 rounded-xl">
                    <p class="text-[11px] font-semibold text-emerald-300" id="simName">Feature Rollout Blueprint</p>
                    <p class="text-[10px] text-emerald-400/80 mt-1" id="simDesc">Initiating webhook connection across core nodes...</p>
                </div>
                
                <div class="flex flex-col gap-2 mt-1" id="simStepsContainer">
                    <div class="flex items-center gap-2 text-[10px] mono" id="step1">
                        <span class="w-4 h-4 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center">1</span>
                        <span class="text-gray-300">Trigger: Zapier MCP Integration Sync</span>
                    </div>
                    <div class="flex items-center gap-2 text-[10px] mono opacity-40 transition-all duration-300" id="step2">
                        <span class="w-4 h-4 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center">2</span>
                        <span class="text-gray-300">Evaluate Context: Cerebras / Groq Routers</span>
                    </div>
                    <div class="flex items-center gap-2 text-[10px] mono opacity-40 transition-all duration-300" id="step3">
                        <span class="w-4 h-4 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center">3</span>
                        <span class="text-gray-300">Orchestrate Code: Claude Code Agent Engine</span>
                    </div>
                    <div class="flex items-center gap-2 text-[10px] mono opacity-40 transition-all duration-300" id="step4">
                        <span class="w-4 h-4 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center">4</span>
                        <span class="text-gray-300">Log Memory Context: Obsidian Vector Store</span>
                    </div>
                    <div class="flex items-center gap-2 text-[10px] mono opacity-40 transition-all duration-300" id="step5">
                        <span class="w-4 h-4 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center">5</span>
                        <span class="text-gray-300">Deploy Changes: Neon DB & Vercel Hosting</span>
                    </div>
                </div>
                
                <div class="flex gap-2 mt-2">
                    <button id="nextSimBtn" onclick="cyclePipeline()" class="flex-1 bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-bold py-1.5 px-3 rounded-lg text-[10px] transition duration-150">
                        Next Pipeline Scenario
                    </button>
                </div>
            </div>
        </div>
    </aside>

    <!-- RIGHT DRAWER: DETAILED INFORMATION NODE OVERLAY & ✨ AI CONSULTANT CHAT -->
    <main id="nodeDetailDrawer" class="absolute right-0 top-24 bottom-4 w-full md:w-[430px] px-4 z-40 pointer-events-none flex flex-col justify-end md:justify-start">
        <div class="pointer-events-auto glass-panel rounded-2xl p-5 flex flex-col gap-4 overflow-y-auto max-h-[85vh] transition-all duration-300 transform translate-x-full" id="drawerBody">
            <!-- Header containing current node details -->
            <div class="flex items-start justify-between border-b border-violet-500/10 pb-4">
                <div class="flex items-center gap-3">
                    <div id="nodeIconBox" class="w-12 h-12 rounded-xl bg-violet-500/10 flex items-center justify-center text-xl text-violet-300 border border-violet-500/20">
                        <i class="fa-solid fa-microchip"></i>
                    </div>
                    <div>
                        <h2 class="text-lg font-extrabold text-white" id="nodeTitle">Select a Node</h2>
                        <span class="text-[10px] uppercase tracking-widest mono text-violet-400/80" id="nodeCategory">Layer Info</span>
                    </div>
                </div>
                <button onclick="closeDrawer()" class="text-gray-400 hover:text-white transition duration-150 touch-target p-1">
                    <i class="fa-solid fa-circle-xmark text-lg"></i>
                </button>
            </div>

            <!-- Tab Selectors for Node Info vs. ✨ Advisor Chat -->
            <div class="flex gap-1 bg-[#0a051e]/60 p-1 rounded-xl border border-violet-500/5">
                <button id="nodeSubTabBtn-spec" onclick="switchNodeSubTab('spec')" class="flex-1 py-1.5 text-[11px] font-semibold rounded-lg text-center transition duration-150 bg-violet-500/15 border border-violet-500/20 text-white">
                    <i class="fa-solid fa-circle-info mr-1"></i>Component Spec
                </button>
                <button id="nodeSubTabBtn-consult" onclick="switchNodeSubTab('consult')" class="flex-1 py-1.5 text-[11px] font-semibold rounded-lg text-center transition duration-150 text-violet-300/60 hover:text-white">
                    <i class="fa-solid fa-user-tie mr-1"></i>✨ Consult Advisor
                </button>
            </div>

            <!-- TAB CONTAINER: SPEC INFO -->
            <div id="nodeSubTab-spec" class="flex flex-col gap-4">
                <!-- Metadata parameters -->
                <div class="grid grid-cols-2 gap-3" id="metaContainer">
                    <div class="bg-[#120a2a]/60 border border-violet-500/5 p-2.5 rounded-xl">
                        <p class="text-[9px] uppercase tracking-wider text-gray-400 font-semibold">Operational Status</p>
                        <p class="text-xs font-bold text-emerald-400 flex items-center gap-1.5 mt-0.5">
                            <span class="w-2 h-2 rounded-full bg-emerald-400"></span> Online / Synced
                        </p>
                    </div>
                    <div class="bg-[#120a2a]/60 border border-violet-500/5 p-2.5 rounded-xl">
                        <p class="text-[9px] uppercase tracking-wider text-gray-400 font-semibold">Data Access Tier</p>
                        <p class="text-xs font-bold text-indigo-300 mt-0.5" id="nodeType">Unified API</p>
                    </div>
                </div>

                <!-- Summary & Description -->
                <div class="flex flex-col gap-1.5">
                    <span class="text-xs font-semibold text-violet-300/80">Description & Context</span>
                    <p class="text-xs leading-relaxed text-gray-300" id="nodeDesc">
                        Select any functional component block in the 3D grid layout to inspect integration protocols, memory sync routines, and automated business parameters.
                    </p>
                </div>

                <!-- Inter-Node Workflows / Connections -->
                <div class="flex flex-col gap-2">
                    <span class="text-xs font-semibold text-violet-300/80">Active Dynamic Connections</span>
                    <div class="flex flex-wrap gap-2" id="nodeConnections">
                        <span class="text-[10px] bg-[#120a2a] px-2.5 py-1 rounded-lg border border-violet-500/10 text-gray-400">No node selected</span>
                    </div>
                </div>

                <!-- Strategic Business Improvement Actions -->
                <div class="flex flex-col gap-2 mt-2 pt-4 border-t border-violet-500/10" id="actionContainer">
                    <span class="text-xs font-semibold text-emerald-400 flex items-center gap-1.5">
                        <i class="fa-solid fa-chart-line text-[10px]"></i> System Enhancements (Added)
                    </span>
                    <div class="bg-emerald-950/10 border border-emerald-500/10 p-3 rounded-xl">
                        <p class="text-[11px] font-bold text-emerald-300" id="actionTitle">MAB AI System Enhancement</p>
                        <p class="text-[10px] text-gray-300 mt-1" id="actionDesc">Click a node to view proactive infrastructure additions and workflow automations.</p>
                    </div>
                </div>
            </div>

            <!-- TAB CONTAINER: ✨ GEMINI ADVISOR CHAT -->
            <div id="nodeSubTab-consult" class="hidden flex flex-col gap-3">
                <div class="bg-[#120a2a]/60 border border-violet-500/15 p-3 rounded-xl">
                    <div class="flex items-center gap-1.5 text-xs text-violet-300 font-bold mb-1">
                        <i class="fa-solid fa-brain"></i> Contextual Knowledge base
                    </div>
                    <p class="text-[11px] text-gray-400">Gemini knows this stack, the available libraries, and can draft instant code files, deployment commands, or architecture pattern checklists.</p>
                </div>

                <!-- Chat Box Screen -->
                <div id="advisorChatHistory" class="bg-[#050117] border border-violet-500/10 rounded-xl p-3 h-[220px] overflow-y-auto flex flex-col gap-2">
                    <div class="bg-violet-950/20 border border-violet-500/10 p-2.5 rounded-xl text-xs text-gray-300">
                        <span class="font-bold text-violet-400 block mb-0.5">✨ Gemini Advisor:</span>
                        Hi, ask me anything about optimizing, programing, or hardening your <b id="chatSelectedNodeName">node</b> infrastructure.
                    </div>
                </div>

                <!-- Chat inputs -->
                <div class="flex gap-2">
                    <input type="text" id="advisorChatInput" onkeydown="if(event.key==='Enter') sendAdvisorMessage()" class="flex-1 bg-[#120a2a] border border-violet-500/20 rounded-xl px-3 py-2 text-xs text-gray-200 focus:outline-none focus:border-violet-400 placeholder-gray-500" placeholder="e.g. Give me integration code...">
                    <button onclick="sendAdvisorMessage()" id="chatSendBtn" class="touch-target px-4 bg-gradient-to-tr from-violet-600 to-indigo-600 hover:from-violet-500 hover:to-indigo-500 rounded-xl text-xs font-bold text-white flex items-center justify-center transition duration-150">
                        ✨ Ask
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- INSTRUCTIONS / ROTATION HELPER OVERLAY (Disappears on hover/interaction) -->
    <div id="instructionOverlay" class="absolute bottom-6 left-1/2 transform -translate-x-1/2 z-30 pointer-events-none flex flex-col items-center justify-center text-center gap-1 transition-all duration-500 bg-[#0c0525]/80 px-6 py-3 rounded-2xl border border-violet-500/20 backdrop-blur-md">
        <div class="flex items-center gap-2 text-violet-300 text-xs font-semibold">
            <i class="fa-solid fa-circle-nodes text-sm animate-pulse"></i>
            <span>Interactive 3D Workspace Architecture</span>
        </div>
        <p class="text-[10px] text-gray-400">Left Click + Drag to Rotate • Right Click + Drag to Pan • Scroll to Zoom • Click Nodes to Inspect</p>
    </div>

    <!-- AUDIO PLAYER ELEMENT (Optional feedback) -->
    <audio id="clickSound" src="https://assets.mixkit.co/active_storage/sfx/2568/2568-84.wav" preload="auto"></audio>

