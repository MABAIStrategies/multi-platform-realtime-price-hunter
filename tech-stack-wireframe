        // Extremely simplified client-side Markdown parser to format advisor outputs
        function parseMarkdown(text) {
            // Replace backticks with mono tags
            text = text.replace(/`([^`]+)`/g, '<code class="mono bg-[#1b123c] px-1 py-0.5 rounded text-violet-300">$1</code>');
            // Bold tag formatting
            text = text.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
            // Bullet list formatting
            text = text.replace(/^\s*[-*]\s+(.*)$/gm, '<li class="ml-4 list-disc">$1</li>');
            // Handle basic multi-line code blocks nicely
            text = text.replace(/```([a-z]*)\n([\s\S]*?)```/g, '<pre class="mono bg-[#030012] p-2 rounded-lg my-1.5 overflow-x-auto text-[10px] text-violet-200 border border-violet-500/10">$2</pre>');
            return text;
        }


