        async function synthesizePipeline() {
            const promptInput = document.getElementById('geminiPromptInput');
            const prompt = promptInput.value.trim();
            if (!prompt) {
                showGeminiAlert("Please Enter a Scenario", "Describe what custom flow you want Gemini to analyze and build.", "error");
                return;
            }

            // Lock synthesis button state
            setSynthesisBtnState(true);
            showGeminiAlert("Analyzing Nodes & Physics...", "Consulting Gemini 2.5-Flash to route optimal architecture path steps.", "loading");

            // Define node database identifiers for prompt safety rules
            const availableNodes = techStackData.map(node => `"${node.id}" (${node.name} under layer ${node.layer})`).join(", ");

            const systemPrompt = `You are the lead Systems Architect at MAB AI STRATEGIES.
Your task is to analyze a user's corporate automation query and synthesize an interactive 3D pipeline trajectory using only valid nodes from our system.

VALID NODES IN INVENTORY:
[${availableNodes}]

Return a structured JSON object with the following properties:
1. "name" (string): Concise title of the business scenario (e.g., "Air-Gapped Sync Sequence").
2. "desc" (string): Summary description of the operations.
3. "path" (array of strings): Exactly 4 to 6 connected node IDs sequentially ordered, demonstrating the data path (e.g., ["slack", "zapier_mcp", "claude_code", "github", "vercel"]). Must use the exact literal string IDs from our inventory list only.
4. "steps" (array of strings): Exactly the same number of step descriptions matching each node in the path sequence. Keep descriptions short and highly technical.

Output MUST be valid JSON adhering exactly to the schema. Do not output markdown surrounding blocks.`;

            const payload = {
                contents: [{
                    parts: [{ text: `Generate a custom scenario pipeline for this prompt: "${prompt}"` }]
                }],
                systemInstruction: {
                    parts: [{ text: systemPrompt }]
                },
                generationConfig: {
                    responseMimeType: "application/json",
                    responseSchema: {
                        type: "OBJECT",
                        properties: {
                            name: { type: "STRING" },
                            desc: { type: "STRING" },
                            path: {
                                type: "ARRAY",
                                items: { type: "STRING" }
                            },
                            steps: {
                                type: "ARRAY",
                                items: { type: "STRING" }
                            }
                        },
                        required: ["name", "desc", "path", "steps"]
                    }
                }
            };

            try {
                const data = await fetchGeminiAPI(payload);
                const rawText = data.candidates?.[0]?.content?.parts?.[0]?.text;
                if (!rawText) {
                    throw new Error("Empty model response received.");
                }

                const parsedScenario = JSON.parse(rawText);
                
                // Validate node matching safety rules to protect ThreeJS execution arrays
                const validPaths = parsedScenario.path.filter(nodeId => techStackData.some(node => node.id === nodeId));
                
                if (validPaths.length < 2) {
                    throw new Error("Gemini couldn't align enough valid physical nodes to construct a trajectory.");
                }

                // Append the generated scenario directly onto the simulation inventory lists
                parsedScenario.path = validPaths;
                pipelineScenarios.push(parsedScenario);
                currentScenarioIndex = pipelineScenarios.length - 1;

                // Stop any current running simulations and boot up the newly generated one
                isSimulating = false;
                togglePipelineSim(); // Turns simulation ON running the fresh pipeline scenario

                showGeminiAlert("Simulation Constructed! ✨", "Watch the 3D grid layout light up dynamically as Gemini executes each step.", "success");
                
                // Switch view automatically to show active simulation elements
                setTimeout(() => {
                    hideGeminiAlert();
                }, 4000);

            } catch (err) {
                console.error("Synthesizer failure:", err);
                showGeminiAlert("Architecture Check Failed", err.message || "An error occurred during system compilation.", "error");
            } finally {
                setSynthesisBtnState(false);
            }
        }

