        function runCurrentScenario() {
            const scenario = pipelineScenarios[currentScenarioIndex];
            document.getElementById('simName').innerText = scenario.name;
            document.getElementById('simDesc').innerText = scenario.desc;

            // Render out dynamic step structure blocks on left-panel overlay
            const stepsContainer = document.getElementById('simStepsContainer');
            stepsContainer.innerHTML = '';
            
            scenario.steps.forEach((stepText, idx) => {
                const nodeKey = scenario.path[idx];
                const stepDiv = document.createElement('div');
                stepDiv.id = `step${idx+1}`;
                stepDiv.className = `flex items-center gap-2 text-[10px] mono ${idx === 0 ? '' : 'opacity-40'} transition-all duration-300`;
                stepDiv.innerHTML = `
                    <span class="w-4 h-4 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center">${idx+1}</span>
                    <span class="text-gray-300">${stepText}</span>
                `;
                stepsContainer.appendChild(stepDiv);
            });

            // Fire running cycle intervals
            clearInterval(simInterval);
            simStepIndex = 0;
            
            runStep();
            simInterval = setInterval(runStep, 3500);
        }

        function runStep() {
            const scenario = pipelineScenarios[currentScenarioIndex];
            const stepsCount = scenario.path.length;

            if (simStepIndex >= stepsCount) {
                // Loop Scenario Step or stay at final
                simStepIndex = 0;
                // Reset step list opacity
                for (let i = 1; i <= stepsCount; i++) {
                    const stepEl = document.getElementById(`step${i}`);
                    if (stepEl) {
                        stepEl.classList.add('opacity-40');
                        stepEl.classList.remove('text-emerald-300', 'font-bold', 'translate-x-1');
                    }
                }
            }

            const currentActiveNodeId = scenario.path[simStepIndex];
            
            // Visually trigger simulation step highlights
            selectNode(currentActiveNodeId);

            // Highlight step text in list drawer panel
            const currentStepEl = document.getElementById(`step${simStepIndex + 1}`);
            if (currentStepEl) {
                currentStepEl.classList.remove('opacity-40');
                currentStepEl.classList.add('text-emerald-300', 'font-bold', 'translate-x-1');
                currentStepEl.querySelector('span:nth-child(1)').classList.add('bg-emerald-500');
                
                // Set step action text description dynamically
                document.getElementById('simDesc').innerText = scenario.steps[simStepIndex];
            }

            // Increment scenario execution cursor
            simStepIndex++;
        }

        function cyclePipeline() {
            currentScenarioIndex = (currentScenarioIndex + 1) % pipelineScenarios.length;
            runCurrentScenario();
        }

