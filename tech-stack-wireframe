        // Create Glowing Concentric Rings representing stack platforms
        function createLayerPlatforms() {
            for (let layerKey in layersMetaData) {
                const layer = layersMetaData[layerKey];
                const y = layer.y;

                // Translucent platform geometry
                const discGeom = new THREE.CylinderGeometry(8, 8, 0.1, 32);
                const discMat = new THREE.MeshPhongMaterial({
                    color: layer.color,
                    transparent: true,
                    opacity: 0.05,
                    shininess: 40,
                    specular: layer.color
                });
                const discMesh = new THREE.Mesh(discGeom, discMat);
                discMesh.position.set(0, y, 0);
                scene.add(discMesh);
                layerDiscsArray.push(discMesh);

                // Glow ring outline
                const ringGeom = new THREE.RingGeometry(8, 8.1, 48);
                const ringMat = new THREE.MeshBasicMaterial({
                    color: layer.color,
                    side: THREE.DoubleSide,
                    transparent: true,
                    opacity: 0.25
                });
                const ringMesh = new THREE.Mesh(ringGeom, ringMat);
                ringMesh.rotation.x = Math.PI / 2;
                ringMesh.position.set(0, y, 0);
                scene.add(ringMesh);

                // Grid lines inside the platform
                const gridHelper = new THREE.GridHelper(16, 8, layer.color, 0x1d143c);
                gridHelper.position.set(0, y, 0);
                gridHelper.material.opacity = 0.15;
                gridHelper.material.transparent = true;
                scene.add(gridHelper);
            }
        }

        // Render 3D geometric nodes representing each tool
        function createArchitectureNodes() {
            techStackData.forEach(node => {
                const color = categoryColors[node.category] || 0xffffff;
                const yPos = layerYOffsets[node.layer];

                // Design 3D Geometry depending on component category for optimal UX visual cueing
                let geometry;
                if (node.category === 'Agents') {
                    geometry = new THREE.IcosahedronGeometry(0.55, 1); // Complex polyhedral sphere for Agents
                } else if (node.category === 'Brain & Models') {
                    geometry = new THREE.OctahedronGeometry(0.5, 0); // Diamond look for models
                } else if (node.category === 'Memory & Context') {
                    geometry = new THREE.BoxGeometry(0.8, 0.8, 0.8); // Robust box for storage nodes
                } else if (node.category.includes('Security')) {
                    geometry = new THREE.ConeGeometry(0.4, 0.8, 4); // Cyber shield cone
                } else {
                    geometry = new THREE.SphereGeometry(0.45, 16, 16); // Normal sphere for databases/hosting
                }

                // Node material with glassmorphism glow qualities
                const material = new THREE.MeshPhongMaterial({
                    color: color,
                    emissive: color,
                    emissiveIntensity: 0.45,
                    shininess: 90,
                    specular: 0xffffff,
                    transparent: true,
                    opacity: 0.95
                });

                const mesh = new THREE.Mesh(geometry, material);
                mesh.position.set(node.gridX, yPos, node.gridZ);
                mesh.castShadow = true;
                mesh.receiveShadow = true;

                // Add simple glow orbit rings around specific starred core elements
                if (node.name.includes("Claude Code") || node.name.includes("Obsidian") || node.name.includes("GitHub") || node.name.includes("Zapier")) {
                    const smallRingGeom = new THREE.RingGeometry(0.8, 0.85, 16);
                    const smallRingMat = new THREE.MeshBasicMaterial({
                        color: color,
                        side: THREE.DoubleSide,
                        transparent: true,
                        opacity: 0.5
                    });
                    const smallRing = new THREE.Mesh(smallRingGeom, smallRingMat);
                    smallRing.rotation.x = Math.PI / 2;
                    mesh.add(smallRing);
                }

                // Keep references
                mesh.userData = { id: node.id, nodeInfo: node };
                scene.add(mesh);
                nodesArray.push(mesh);
            });
        }

        // Render data line pathways linking the multi-layer nodes
        function createInterNodeConnections() {
            connectionsArray.forEach(line => scene.remove(line));
            connectionsArray = [];

            techStackData.forEach(originNode => {
                const originMesh = nodesArray.find(n => n.userData.id === originNode.id);
                if (!originMesh) return;

                originNode.connections.forEach(targetId => {
                    const targetMesh = nodesArray.find(n => n.userData.id === targetId);
                    if (!targetMesh) return;

                    // Draw nice dynamic curves instead of stark lines for an impressive aesthetic
                    const start = originMesh.position;
                    const end = targetMesh.position;

                    // Calculate midpoint to introduce a soft bend logic
                    const midX = (start.x + end.x) / 2;
                    const midY = (start.y + end.y) / 2 + (start.y === end.y ? 0 : 0.8);
                    const midZ = (start.z + end.z) / 2;
                    const mid = new THREE.Vector3(midX, midY, midZ);

                    const curve = new THREE.QuadraticBezierCurve3(start, mid, end);
                    const curvePoints = curve.getPoints(24);

                    const lineGeom = new THREE.BufferGeometry().setFromPoints(curvePoints);
                    
                    // Simple path coloring: merge both origin and destination node colors
                    const originCol = categoryColors[originNode.category];
                    const targetCol = categoryColors[targetMesh.userData.nodeInfo.category];
                    const colorLerp = new THREE.Color(originCol).lerp(new THREE.Color(targetCol), 0.5);

                    const lineMat = new THREE.LineBasicMaterial({
                        color: colorLerp,
                        transparent: true,
                        opacity: 0.15,
                        linewidth: 1
                    });

                    const line = new THREE.Line(lineGeom, lineMat);
                    line.userData = {
                        originId: originNode.id,
                        targetId: targetId,
                        color: colorLerp
                    };
                    scene.add(line);
                    connectionsArray.push(line);
                });
            });
        }

        // -------------------------------------------------------------
        // ANIMATION LOOP & ROTATION MECHANICAL SETUP
        // -------------------------------------------------------------
        function animate() {
            requestAnimationFrame(animate);

            // Subtle rotation adjustments to the environment and active node elements
            const time = Date.now() * 0.001;

            nodesArray.forEach(mesh => {
                // Pulse size fluctuation very gently
                const pulse = 1 + Math.sin(time * 2 + mesh.position.x) * 0.03;
                mesh.scale.set(pulse, pulse, pulse);

                // Rotate Agent polyhedrals and model shapes at different speeds
                if (mesh.userData.nodeInfo.category === 'Agents') {
                    mesh.rotation.y += 0.006;
                } else if (mesh.userData.nodeInfo.category === 'Brain & Models') {
                    mesh.rotation.x += 0.004;
                    mesh.rotation.z += 0.003;
                } else {
                    mesh.rotation.y += 0.002;
                }
            });

            // Rotate outer glow rings
            layerDiscsArray.forEach((disc, index) => {
                disc.rotation.y = Math.sin(time * 0.1 + index) * 0.15;
            });

            // Smooth camera transition if focused on specific coordinates
            controls.update();
            renderer.render(scene, camera);
        }

