        // Handle Hover States for visual highlighting feedback
        function onMouseMove(event) {
            const container = document.getElementById('canvas-container');
            const rect = renderer.domElement.getBoundingClientRect();
            
            // Normalized coordinates mapping
            mouse.x = ((event.clientX - rect.left) / container.clientWidth) * 2 - 1;
            mouse.y = -((event.clientY - rect.top) / container.clientHeight) * 2 + 1;

            raycaster.setFromCamera(mouse, camera);
            const intersects = raycaster.intersectObjects(nodesArray);

            if (intersects.length > 0) {
                document.getElementById('canvas-container').style.cursor = 'pointer';
                const nodeMesh = intersects[0].object;

                if (highlightedNode !== nodeMesh) {
                    // Reset old highlighted node emissive factor
                    if (highlightedNode) {
                        const baseColor = categoryColors[highlightedNode.userData.nodeInfo.category];
                        highlightedNode.material.emissive.setHex(baseColor);
                        highlightedNode.material.emissiveIntensity = 0.45;
                    }

                    // Intense highlight on current node
                    highlightedNode = nodeMesh;
                    highlightedNode.material.emissive.setHex(0xffffff);
                    highlightedNode.material.emissiveIntensity = 0.8;
                }
            } else {
                document.getElementById('canvas-container').style.cursor = 'grab';
                if (highlightedNode) {
                    const baseColor = categoryColors[highlightedNode.userData.nodeInfo.category];
                    highlightedNode.material.emissive.setHex(baseColor);
                    highlightedNode.material.emissiveIntensity = 0.45;
                    highlightedNode = null;
                }
            }
        }

