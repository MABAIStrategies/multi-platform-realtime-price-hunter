            renderer.shadowMap.enabled = true;
            container.appendChild(renderer.domElement);

            // Controls Setup
            controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.maxPolarAngle = Math.PI / 2 + 0.1; // Limit panning too far below floor
            controls.minDistance = 5;
            controls.maxDistance = 60;

            // Ambient & Directional Lights
            const ambientLight = new THREE.AmbientLight(0x0e0a2b, 2.5);
            scene.add(ambientLight);

            const dirLight1 = new THREE.DirectionalLight(0x8b5cf6, 2.5);
            dirLight1.position.set(20, 40, 20);
            scene.add(dirLight1);

            const dirLight2 = new THREE.DirectionalLight(0x06b6d4, 1.5);
            dirLight2.position.set(-20, -10, -20);
